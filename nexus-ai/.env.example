# ── NEXUS AI — Environment Configuration ─────────────────────────
# Copy this to backend/.env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/nexus-ai

# JWT (change in production!)
JWT_SECRET=nexus_ai_super_secret_key_2024_CHANGE_ME
JWT_EXPIRES_IN=7d

# Google OAuth (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id_here

# OpenAI (get from platform.openai.com) — optional, has rule-based fallback
OPENAI_API_KEY=your_openai_api_key_here

# ML Service
ML_SERVICE_URL=http://localhost:8000

# Frontend
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here
